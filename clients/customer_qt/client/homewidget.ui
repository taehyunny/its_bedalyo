  <property name="styleSheet">
   <string>
QWidget#HomeWidget {
  background-color: #f5f5f5;
}

/* ── 상단 헤더 ── */
QWidget#headerWidget {
  background-color: #ffffff;
}
QLabel#label_appName {
  font-size: 22px;
  font-weight: bold;
  color: #1565c0;
}
QLabel#label_location {
  font-size: 13px;
  color: #555555;
}
QPushButton#btnNotification {
  background: transparent;
  border: none;
  font-size: 20px;
  padding: 4px;
}
QPushButton#btnNotification:hover {
  background-color: #f0f0f0;
  border-radius: 20px;
}

/* ── 배너 ── */
QWidget#bannerWidget {
  background-color: #1565c0;
  border-radius: 14px;
}
QLabel#label_bannerTitle {
  font-size: 16px;
  font-weight: bold;
  color: #ffffff;
  background: transparent;
}
QLabel#label_bannerSub {
  font-size: 12px;
  color: rgba(255,255,255,0.85);
  background: transparent;
}
QLabel#label_bannerIcon {
  font-size: 40px;
  background: transparent;
}

/* ── 카테고리 버튼 ── */
QPushButton#btnCatAll, QPushButton#btnCatKorean,
QPushButton#btnCatChinese, QPushButton#btnCatJapanese,
QPushButton#btnCatWestern, QPushButton#btnCatCafe,
QPushButton#btnCatBakery, QPushButton#btnCatChicken {
  background-color: #ffffff;
  border: 1.5px solid #e8e8e8;
  border-radius: 20px;
  font-size: 12px;
  font-weight: bold;
  color: #444444;
  padding: 6px 14px;
  min-height: 34px;
}
QPushButton#btnCatAll {
  background-color: #1565c0;
  color: #ffffff;
  border: 1.5px solid #1565c0;
}
QPushButton#btnCatAll:hover,
QPushButton#btnCatKorean:hover, QPushButton#btnCatChinese:hover,
QPushButton#btnCatJapanese:hover, QPushButton#btnCatWestern:hover,
QPushButton#btnCatCafe:hover, QPushButton#btnCatBakery:hover,
QPushButton#btnCatChicken:hover {
  background-color: #e3f0ff;
  border-color: #1565c0;
  color: #1565c0;
}

/* ── 섹션 제목 ── */
QLabel#label_sectionTitle {
  font-size: 17px;
  font-weight: bold;
  color: #111111;
}
QLabel#label_sectionSub {
  font-size: 12px;
  color: #999999;
}

/* ── 가게 목록 ── */
QListWidget#storeList {
  background-color: transparent;
  border: none;
  outline: none;
}
QListWidget#storeList::item {
  background-color: #ffffff;
  border-radius: 12px;
  margin: 4px 16px;
  padding: 0px;
}
QListWidget#storeList::item:selected {
  background-color: #e8f0ff;
}
QListWidget#storeList::item:hover {
  background-color: #f5f9ff;
}

/* ── 하단 내비게이션 바 ── */
QWidget#navBar {
  background-color: #ffffff;
  border-top: 1px solid #eeeeee;
}
QPushButton#navHome, QPushButton#navSearch,
QPushButton#navOrder, QPushButton#navMypage {
  background: transparent;
  border: none;
  font-size: 11px;
  color: #999999;
  padding: 6px 4px;
}
QPushButton#navHome {
  color: #1565c0;
}
QPushButton#navHome:hover, QPushButton#navSearch:hover,
QPushButton#navOrder:hover, QPushButton#navMypage:hover {
  color: #1565c0;
}
