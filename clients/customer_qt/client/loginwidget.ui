   <string>
QWidget#LoginWidget { background-color: #ffffff; }
QLineEdit {
  border: 1.5px solid #e0e0e0;
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 14px;
  color: #222222;
  background-color: #fafafa;
}
QLineEdit:focus { border: 1.5px solid #1565c0; background-color: #ffffff; }
QLineEdit:disabled { background-color: #f0f0f0; color: #aaaaaa; }

QPushButton#loginButton {
  background-color: #1565c0; color: white; border: none;
  border-radius: 10px; font-size: 16px; font-weight: bold;
  padding: 14px; min-height: 50px;
}
QPushButton#loginButton:hover { background-color: #1976d2; }
QPushButton#loginButton:pressed { background-color: #0d47a1; }

QPushButton#signupButton {
  background-color: #1565c0; color: white; border: none;
  border-radius: 10px; font-size: 16px; font-weight: bold;
  padding: 14px; min-height: 50px;
}
QPushButton#signupButton:hover { background-color: #1976d2; }
QPushButton#signupButton:pressed { background-color: #0d47a1; }
QPushButton#signupButton:disabled {
  background-color: #cccccc; color: #888888;
}

QPushButton#btnCheckId, QPushButton#btnCheckPhone {
  background-color: #1565c0; color: white; border: none;
  border-radius: 8px; font-size: 12px; font-weight: bold;
  min-width: 72px; max-width: 72px; min-height: 44px;
}
QPushButton#btnCheckId:hover, QPushButton#btnCheckPhone:hover { background-color: #1976d2; }
QPushButton#btnCheckId:disabled, QPushButton#btnCheckPhone:disabled {
  background-color: #aaaaaa;
}

QPushButton#tabLogin, QPushButton#tabSignup {
  background-color: transparent; border: none;
  border-bottom: 2px solid transparent;
  font-size: 16px; font-weight: bold; color: #bbbbbb; padding: 10px 0px;
}
