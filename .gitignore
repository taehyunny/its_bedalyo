# ==========================================
#  ITS 배달 프로젝트 .gitignore
# ==========================================


# ------------------------------------------
#  CMake 빌드 산출물
# ------------------------------------------
build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
*.cmake
!CMakeLists.txt


# ------------------------------------------
#  Visual Studio / VS Code
# ------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docview
*.vcxproj.filters
*.vcxproj.user
*.aps
*.ncb
*.sdf
*.opensdf
*.cachefile
*.VC.db
*.VC.VC.opendb
ipch/
Debug/
Release/
x64/
x86/
Win32/
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
# .vscode/extensions.json 은 팀 공유 목적이므로 유지


# ------------------------------------------
#  Qt 빌드 산출물 (customer_qt, store_qt)
# ------------------------------------------
*.pro.user
*.pro.user.*
*.qbs.user
*.qbs.user.*
*.moc
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp
Makefile
Makefile.*
object_script.*
*.prl
*.so
*.dylib
*.a


# ------------------------------------------
#  MFC / Windows 빌드 산출물 (admin_mfc)
# ------------------------------------------
*.obj
*.pch
*.pdb
*.ilk
*.exp
*.lib
*.dll
*.exe
*.res
*.rc2
*.tlb
*.tlh
*.sbr
*.bsc
GeneratedFiles/
*.manifest
*.idb
*.iobj
*.ipdb


# ------------------------------------------
#  Python (rider_py)
# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
.env
.venv
env/
venv/
*.egg-info/
dist/
*.egg
pip-log.txt


# ------------------------------------------
#  컴파일러 일반 산출물
# ------------------------------------------
*.o
*.d
*.map
*.out


# ------------------------------------------
#  운영체제 자동 생성 파일
# ------------------------------------------

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*


# ------------------------------------------
#  DB / 민감 정보
# ------------------------------------------
*.db
*.sqlite
*.sqlite3
*.sql.bak
.env
.env.*
config.ini
secrets.*
credentials.*


# ------------------------------------------
#  로그 / 임시 파일
# ------------------------------------------
*.log
*.tmp
*.temp
*.swp
*.bak
*.orig
logs/
